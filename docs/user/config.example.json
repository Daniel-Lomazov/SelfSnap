{
  "schema_version": 3,
  "app_enabled": false,
  "first_run_completed": false,
  "storage_preset": "local_pictures",
  "capture_storage_root": "%USERPROFILE%\\Pictures\\SelfSnap\\captures",
  "archive_storage_root": "%USERPROFILE%\\Pictures\\SelfSnap\\archive",
  "retention_mode": "keep_forever",
  "retention_days": null,
  "purge_enabled": false,
  "retention_grace_days": 30,
  "capture_mode": "composite",
  "image_format": "png",
  "image_quality": 85,
  "start_tray_on_login": true,
  "log_level": "INFO",
  "show_last_capture_status": true,
  "notify_on_failed_or_missed": true,
  "notify_on_every_capture": false,
  "show_capture_overlay": false,
  "wake_for_scheduled_captures": false,
  "scheduler_sync_state": "ok",
  "scheduler_sync_message": null,
  "settings_window_width": 960,
  "settings_window_height": 760,
  "slot_match_tolerance_seconds": 120,
  "schedules": [
    {
      "schedule_id": "sched_morning01",
      "label": "Morning",
      "enabled": true,
      "interval_value": 1,
      "interval_unit": "day",
      "start_date_local": "2026-03-23",
      "start_time_local": "09:00:00"
    },
    {
      "schedule_id": "sched_workbreak01",
      "label": "Work Break",
      "enabled": true,
      "interval_value": 5,
      "interval_unit": "minute",
      "start_date_local": "2026-03-23",
      "start_time_local": "14:30:00"
    }
  ]
}